{%- liquid
  assign accent = section.settings.accent_color
  assign accent_r = accent | color_extract: 'red'
  assign accent_g = accent | color_extract: 'green'
  assign accent_b = accent | color_extract: 'blue'
  assign accent_light = accent | color_lighten: 15
  assign accent_dark = accent | color_darken: 20
-%}

<div
  class="password-page full-width"
  style="
    --accent: {{ accent }};
    --accent-light: {{ accent_light }};
    --accent-dark: {{ accent_dark }};
    --accent-r: {{ accent_r }};
    --accent-g: {{ accent_g }};
    --accent-b: {{ accent_b }};
  "
>
  <div class="password-page__glow password-page__glow--warm"></div>
  <div class="password-page__glow password-page__glow--red"></div>

  <div class="password-page__content">
    <div class="password-page__brand" style="--delay: 0s">
      {{ section.settings.brand_name }}<span class="password-page__tm">™</span>
    </div>

    <div class="password-page__badge" style="--delay: 0.08s">
      <span class="password-page__badge-dot"></span>
      {{ section.settings.badge_text }}
    </div>

    <h1 class="password-page__heading" style="--delay: 0.14s">
      <span class="password-page__heading-accent">{{ section.settings.heading_accent }}</span>
      <br>{{ section.settings.heading }}
    </h1>

    <div class="password-page__divider" style="--delay: 0.2s"></div>

    <div class="password-page__description" style="--delay: 0.26s">
      {{ section.settings.description }}
    </div>

    <div class="password-page__form" style="--delay: 0.32s">
      {% form 'customer' %}
        {% if form.posted_successfully? %}
          <div class="password-page__success">
            <div class="password-page__success-icon">✓</div>
            <div>
              <div class="password-page__success-title">{{ section.settings.success_title }}</div>
              <div class="password-page__success-message">{{ section.settings.success_message }}</div>
            </div>
          </div>
        {% else %}
          <input type="hidden" name="contact[tags]" value="prospect,waitlist">
          <input type="hidden" name="contact[accepts_marketing]" value="true">

          {% if form.errors %}
            <div class="password-page__form-error">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}

          <div class="password-page__form-fields">
            <input
              type="email"
              name="contact[email]"
              class="password-page__input"
              placeholder="{{ 'password.email_placeholder' | t }}"
              required
              autocomplete="email"
            >
            <button type="submit" class="password-page__button">
              {{ section.settings.button_text }}
            </button>
          </div>
          <div class="password-page__disclaimer">
            {{ section.settings.disclaimer_text }}
          </div>
        {% endif %}
      {% endform %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="password-page__pillars" style="--delay: 0.4s">
        {% for block in section.blocks %}
          <div class="password-page__pillar" {{ block.shopify_attributes }}>
            <span class="password-page__pillar-icon">{{ block.settings.icon }}</span>
            <span class="password-page__pillar-label">{{ block.settings.label }}</span>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    <button
      class="password-page__password-toggle"
      onclick="document.getElementById('password-dialog-{{ section.id }}').showModal()"
    >
      {{ 'password.enter_password' | t }}
    </button>
  </div>

  <div class="password-page__image">
    {% if section.settings.product_image %}
      <div class="password-page__image-frame">
        {{ section.settings.product_image | image_url: width: 1200 | image_tag: class: 'password-page__image-img' }}
      </div>
    {% else %}
      <div class="password-page__image-placeholder">
        <div>
          <div class="password-page__image-placeholder-label">[ product shot ]</div>
          <div class="password-page__image-placeholder-hint">drop hero jar image here · 4:5</div>
        </div>
      </div>
    {% endif %}
  </div>

  <dialog class="password-page__dialog" id="password-dialog-{{ section.id }}">
    <div class="password-page__dialog-content">
      <button class="password-page__dialog-close" onclick="this.closest('dialog').close()" aria-label="{{ 'password.close' | t }}">✕</button>
      <h2 class="password-page__dialog-title">{{ 'password.title' | t }}</h2>

      {% if shop.password_message %}
        <p class="password-page__dialog-message">{{ shop.password_message }}</p>
      {% endif %}

      {% form 'storefront_password' %}
        {% if form.errors %}
          <div class="password-page__form-error">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="password-page__dialog-form">
          <input
            type="password"
            name="password"
            class="password-page__input"
            placeholder="{{ 'password.password' | t }}"
          >
          <button type="submit" class="password-page__button">
            {{ 'password.enter' | t }}
          </button>
        </div>
      {% endform %}
    </div>
  </dialog>
</div>

{% stylesheet %}
  @keyframes password-glow {
    0%, 100% { opacity: 0.55; }
    50% { opacity: 0.9; }
  }

  @keyframes password-fade {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .password-page {
    min-height: 100vh;
    width: 100%;
    background: #0a0705;
    font-family: 'Manrope', system-ui, sans-serif;
    display: flex;
    align-items: stretch;
    overflow: hidden;
    position: relative;
  }

  .password-page__glow {
    position: absolute;
    pointer-events: none;
  }

  .password-page__glow--warm {
    top: -10%;
    right: 18%;
    width: 60vw;
    height: 90vh;
    background: radial-gradient(
      ellipse at center,
      rgba(var(--accent-r), var(--accent-g), var(--accent-b), 0.22) 0%,
      rgba(var(--accent-r), var(--accent-g), var(--accent-b), 0.06) 38%,
      rgba(10, 7, 5, 0) 68%
    );
    animation: password-glow 7s ease-in-out infinite;
  }

  .password-page__glow--red {
    bottom: -30%;
    right: 22%;
    width: 50vw;
    height: 60vh;
    background: radial-gradient(
      ellipse at center,
      rgba(150, 40, 30, 0.16) 0%,
      rgba(10, 7, 5, 0) 60%
    );
  }

  .password-page__content {
    flex: 1 1 52%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(40px, 6vw, 96px);
    position: relative;
    z-index: 2;
    max-width: 780px;
  }

  .password-page__brand,
  .password-page__badge,
  .password-page__heading,
  .password-page__divider,
  .password-page__description,
  .password-page__form,
  .password-page__pillars {
    animation: password-fade 0.7s ease var(--delay, 0s) both;
  }

  .password-page__brand {
    font-size: clamp(28px, 3vw, 38px);
    font-weight: 700;
    letter-spacing: -0.5px;
    color: var(--accent);
  }

  .password-page__tm {
    font-size: 0.5em;
    vertical-align: super;
    color: var(--accent-dark);
  }

  .password-page__badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: clamp(36px, 5vw, 64px);
    padding: 7px 14px;
    border: 1px solid rgba(var(--accent-r), var(--accent-g), var(--accent-b), 0.32);
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2.5px;
    color: var(--accent);
    text-transform: uppercase;
    width: fit-content;
  }

  .password-page__badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent);
  }

  .password-page__heading {
    margin: 26px 0 0;
    font-size: clamp(40px, 5.4vw, 72px);
    line-height: 1.02;
    font-weight: 800;
    letter-spacing: -1.5px;
    color: #efe7d6;
  }

  .password-page__heading-accent {
    color: var(--accent);
  }

  .password-page__divider {
    width: 120px;
    height: 1px;
    margin: 30px 0 26px;
    background: linear-gradient(
      90deg,
      var(--accent),
      rgba(var(--accent-r), var(--accent-g), var(--accent-b), 0)
    );
  }

  .password-page__description {
    max-width: 480px;
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.6;
    color: #b6ab97;
  }

  .password-page__description p {
    margin: 0;
  }

  .password-page__description strong {
    color: #d9c9a4;
    font-weight: 700;
  }

  .password-page__form {
    margin-top: 34px;
    max-width: 480px;
  }

  .password-page__form-fields {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .password-page__input {
    flex: 1 1 240px;
    min-width: 0;
    padding: 16px 18px;
    font-size: 15px;
    font-family: inherit;
    color: #efe7d6;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(var(--accent-r), var(--accent-g), var(--accent-b), 0.28);
    border-radius: 12px;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
  }

  .password-page__input:focus {
    border-color: var(--accent);
    background: rgba(var(--accent-r), var(--accent-g), var(--accent-b), 0.06);
  }

  .password-page__input::placeholder {
    color: #6f6555;
  }

  .password-page__button {
    flex: 0 0 auto;
    padding: 16px 28px;
    font-size: 15px;
    font-weight: 700;
    font-family: inherit;
    letter-spacing: 0.3px;
    color: #1a120a;
    background: linear-gradient(180deg, var(--accent-light), var(--accent));
    border: none;
    border-radius: 12px;
    cursor: pointer;
    box-shadow: 0 6px 24px rgba(var(--accent-r), var(--accent-g), var(--accent-b), 0.28);
    transition: filter 0.2s, box-shadow 0.2s;
  }

  .password-page__button:hover {
    filter: brightness(1.08);
    box-shadow: 0 8px 30px rgba(var(--accent-r), var(--accent-g), var(--accent-b), 0.42);
  }

  .password-page__disclaimer {
    margin-top: 11px;
    font-size: 12.5px;
    color: #6f6555;
  }

  .password-page__form-error {
    margin-bottom: 12px;
    padding: 10px 14px;
    border-radius: 8px;
    background: rgba(200, 50, 50, 0.1);
    border: 1px solid rgba(200, 50, 50, 0.3);
    color: #e8a0a0;
    font-size: 14px;
  }

  .password-page__success {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 22px;
    border: 1px solid rgba(var(--accent-r), var(--accent-g), var(--accent-b), 0.35);
    border-radius: 12px;
    background: rgba(var(--accent-r), var(--accent-g), var(--accent-b), 0.06);
    animation: password-fade 0.5s ease both;
  }

  .password-page__success-icon {
    flex: none;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1.5px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    font-size: 15px;
  }

  .password-page__success-title {
    color: #efe7d6;
    font-weight: 700;
    font-size: 16px;
  }

  .password-page__success-message {
    color: #9a8f7c;
    font-size: 13.5px;
    margin-top: 2px;
  }

  .password-page__pillars {
    display: flex;
    gap: clamp(28px, 4vw, 52px);
    margin-top: clamp(40px, 5vw, 64px);
  }

  .password-page__pillar {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }

  .password-page__pillar-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 30px;
    line-height: 1;
    color: var(--accent-light);
    filter: drop-shadow(0 0 8px rgba(var(--accent-r), var(--accent-g), var(--accent-b), 0.5));
  }

  .password-page__pillar-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    color: #b6ab97;
  }

  .password-page__password-toggle {
    margin-top: 40px;
    padding: 0;
    background: none;
    border: none;
    color: #6f6555;
    font-family: inherit;
    font-size: 13px;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
    align-self: flex-start;
  }

  .password-page__password-toggle:hover {
    color: #b6ab97;
  }

  .password-page__image {
    flex: 1 1 48%;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
  }

  .password-page__image-frame {
    width: 100%;
    max-width: 560px;
  }

  .password-page__image-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .password-page__image-placeholder {
    width: 100%;
    max-width: 560px;
    aspect-ratio: 4 / 5;
    border-radius: 16px;
    overflow: hidden;
    background: repeating-linear-gradient(
      45deg,
      #14100b 0px, #14100b 14px,
      #181208 14px, #181208 28px
    );
    border: 1px solid rgba(var(--accent-r), var(--accent-g), var(--accent-b), 0.18);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
    text-align: center;
  }

  .password-page__image-placeholder-label {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 13px;
    letter-spacing: 1px;
    color: #8a7a55;
    text-transform: uppercase;
  }

  .password-page__image-placeholder-hint {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 11px;
    color: #5c5238;
    margin-top: 8px;
  }

  .password-page__dialog {
    border: none;
    border-radius: 16px;
    background: #14100b;
    color: #efe7d6;
    padding: 0;
    max-width: 420px;
    width: 90vw;
  }

  .password-page__dialog::backdrop {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
  }

  .password-page__dialog-content {
    padding: 40px;
    position: relative;
  }

  .password-page__dialog-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: #6f6555;
    font-size: 18px;
    cursor: pointer;
    padding: 4px;
    line-height: 1;
    transition: color 0.2s;
  }

  .password-page__dialog-close:hover {
    color: #b6ab97;
  }

  .password-page__dialog-title {
    font-size: 22px;
    font-weight: 700;
    margin: 0 0 8px;
    font-family: 'Manrope', system-ui, sans-serif;
  }

  .password-page__dialog-message {
    color: #9a8f7c;
    font-size: 14px;
    margin: 0 0 20px;
  }

  .password-page__dialog-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .password-page__dialog-form .password-page__input {
    flex: none;
    width: 100%;
  }

  .password-page__dialog-form .password-page__button {
    width: 100%;
  }

  @media (max-width: 768px) {
    .password-page {
      flex-direction: column;
    }

    .password-page__content {
      max-width: none;
    }

    .password-page__image {
      padding: 0 clamp(20px, 6vw, 40px) clamp(40px, 6vw, 60px);
    }

    .password-page__image-placeholder,
    .password-page__image-frame {
      max-width: none;
    }

    .password-page__heading {
      font-size: clamp(32px, 8vw, 48px);
    }

    .password-page__pillars {
      flex-wrap: wrap;
    }
  }
{% endstylesheet %}

{% javascript %}
  var dialog = document.querySelector('.password-page__dialog');
  if (dialog && dialog.querySelector('.password-page__form-error')) {
    dialog.showModal();
  }
{% endjavascript %}

{% schema %}
{
  "name": "t:password.name",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "t:password.labels.brand_name",
      "default": "MindBites"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "t:password.labels.badge_text",
      "default": "Store opening soon"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "t:password.labels.heading_accent",
      "default": "Something is"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:password.labels.heading",
      "default": "brewing in the dark."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:password.labels.description",
      "default": "<p>We're putting the finishing touches on something that powers you up <strong>without burning you out</strong>. Join the waitlist and be the first through the door — <strong>no crash, no FOMO.</strong></p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:password.labels.button_text",
      "default": "Notify me"
    },
    {
      "type": "text",
      "id": "disclaimer_text",
      "label": "t:password.labels.disclaimer_text",
      "default": "Early-access drops + a launch-day discount. No spam."
    },
    {
      "type": "text",
      "id": "success_title",
      "label": "t:password.labels.success_title",
      "default": "You're on the list."
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "t:password.labels.success_message",
      "default": "We'll email you the moment the doors open."
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "t:password.labels.product_image"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "t:password.labels.accent_color",
      "default": "#c79a4f"
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "t:password.blocks.pillar",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "t:password.labels.icon",
          "default": "◯"
        },
        {
          "type": "text",
          "id": "label",
          "label": "t:password.labels.label",
          "default": "FEATURE"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:password.name",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "icon": "∧",
            "label": "BOOST"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "icon": "◯",
            "label": "FOCUS"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "icon": "∞",
            "label": "SUSTAIN"
          }
        }
      ]
    }
  ]
}
{% endschema %}
